# Server
PORT=8787
APP_URL=https://your-frontend.vercel.app

# Supabase (required for auth + reminders)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Gmail App Password; required for reminders + password reset)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
MAIL_FROM=QuickTasks <your@gmail.com>

# Optional: secret for cron-job.org (header: x-cron-secret). If set, /api/reminders/send-daily requires it.
CRON_SECRET=811e0a7c8e944bc1beaa3f48e6fa4cd8

# Optional: public API URL for CORS / frontend (e.g. Render URL)
# VITE_API_URL is usually set in Frontend .env
